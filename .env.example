# ============================================================
# BOBDOEDUC VERSION B — VARIABLES D'ENVIRONNEMENT
# ============================================================

# ── SERVEUR ──────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://votre-domaine.com
BACKEND_URL=https://api.votre-domaine.com
# BACKEND_URL est utilisé pour générer les liens d'activation dans les emails

# ── BASE DE DONNÉES ───────────────────────────────────────────
# DB_TYPE: postgres | mysql | supabase | sqlite
DB_TYPE=postgres
DATABASE_URL=postgresql://user:password@host:5432/bobdoeduc
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bobdoeduc
DB_USER=bobdoeduc_user
DB_PASSWORD=votre_mot_de_passe
DB_SSL=false

# ── JWT & CHIFFREMENT ─────────────────────────────────────────
JWT_SECRET=GENEREZ_64_CHARS_ALEATOIRES
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_KEY=GENEREZ_32_CHARS_HEX
HMAC_SECRET=AUTRE_32_CHARS_HEX
BCRYPT_ROUNDS_PASSWORD=12
BCRYPT_ROUNDS_PIN=10
BCRYPT_ROUNDS_OTP=8

# ── ABONNEMENTS ───────────────────────────────────────────────
FREE_QUIZ_LIMIT=20
PREMIUM_MONTHLY_PRICE=3000
PREMIUM_YEARLY_PRICE=15000

# ── EMAIL (NOTIFICATION ADMIN) ────────────────────────────────
# Choisir: gmail | smtp | (vide = mode dev, logs console)
EMAIL_PROVIDER=gmail

# Option A — Gmail (recommandé pour démarrer)
# 1. myaccount.google.com → Sécurité → Validation 2 étapes → Activer
# 2. Sécurité → Mots de passe des applications → Créer → Copier
GMAIL_USER=votre-email@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
# ⚠️ Ce mot de passe est différent de votre mot de passe Gmail normal

# Option B — SMTP personnalisé (Brevo, Mailtrap, etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre@email.com
# SMTP_PASS=votre_mot_de_passe_smtp

# ── ADRESSE EMAIL ADMIN ───────────────────────────────────────
# ⚠️ C'est L'ADRESSE où vous recevrez les demandes d'abonnement
ADMIN_EMAIL=votre-email-admin@gmail.com

# Optionnel: envoyer aussi un email à l'utilisateur (nécessite que l'email soit stocké)
SEND_USER_EMAIL=false

# ── ADMIN KEY ─────────────────────────────────────────────────
ADMIN_SECRET_KEY=votre-cle-admin-secrete-longue
# Utilisé pour: panel admin, routes /api/admin/*, /api/questions/*
